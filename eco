<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Planet SPE - Ecosystem Revival</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI', sans-serif;
}

body{
    height:100vh;
    background:radial-gradient(circle at top, #061a17, #010508);
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    position:relative;
}

/* BACK BUTTON */
.back-btn{
    position:absolute;
    top:20px;
    left:20px;
    padding:8px 14px;
    border-radius:12px;
    border:1px solid #6affc6;
    background:rgba(106,255,198,0.1);
    color:white;
    font-size:14px;
    text-decoration:none;
    transition:0.3s;
    z-index:1000;
}

.back-btn:hover{
    background:#6affc6;
    color:black;
    transform:scale(1.05);
}

/* CONTAINER */
.container{
    width:90%;
    max-width:1000px;
    background:rgba(255,255,255,0.05);
    border-radius:20px;
    padding:30px;
    backdrop-filter:blur(15px);
    box-shadow:0 0 40px rgba(0,255,170,0.2);
}

/* HEADER */
.header{
    text-align:center;
    margin-bottom:25px;
}

.header h1{
    font-size:42px;
    color:#6affc6;
}

.header p{
    opacity:0.8;
}

/* GRID */
.grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:20px;
}

/* ACTION BUTTONS */
.action{
    padding:18px;
    border-radius:14px;
    border:1px solid rgba(106,255,198,0.4);
    background:rgba(106,255,198,0.08);
    cursor:pointer;
    transition:0.3s;
    text-align:center;
}

.action:hover{
    transform:translateY(-4px);
    background:#6affc6;
    color:black;
}

/* INFO BOX */
.info{
    grid-column:span 2;
    margin-top:10px;
    padding:20px;
    border-radius:14px;
    background:rgba(0,0,0,0.4);
    font-size:18px;
    line-height:1.5;
}

.highlight{
    color:#6affc6;
}

/* PROGRESS BAR */
.progress{
    margin-top:15px;
    height:12px;
    background:rgba(255,255,255,0.1);
    border-radius:10px;
    overflow:hidden;
}

.bar{
    height:100%;
    width:0%;
    background:#6affc6;
    transition:0.5s;
}
</style>
</head>

<body>

<!-- BACK BUTTON (WORKING LINK) -->
<a href="index.html" class="back-btn">🪐Xeron-9</a>

<div class="container">

<div class="header">
    <h1>Planet SPE</h1>
    <p>Ecosystem Revival Mode</p>
</div>

<div class="grid">

<div class="action" onclick="update('forest')">🌱 Grow Forest</div>
<div class="action" onclick="update('ocean')">🌊 Create Oceans</div>
<div class="action" onclick="update('air')">☁️ Balance Atmosphere</div>
<div class="action" onclick="update('life')">🐾 Introduce Life</div>

<div class="info" id="infoBox">
Ecosystem offline. Begin restoration.
</div>

<div class="progress">
    <div class="bar" id="bar"></div>
</div>

</div>

</div>

<script>
let progress = 0;

function update(type){
    let text = "";

    if(type === "forest"){
        text = "<span class='highlight'>Vegetation Expanding</span><br>Forests spreading across the surface.";
        progress += 25;
    }

    if(type === "ocean"){
        text = "<span class='highlight'>Hydrosphere Formed</span><br>Oceans stabilizing climate systems.";
        progress += 25;
    }

    if(type === "air"){
        text = "<span class='highlight'>Atmosphere Balanced</span><br>Air quality improving rapidly.";
        progress += 25;
    }

    if(type === "life"){
        text = "<span class='highlight'>Life Initiated</span><br>New organisms beginning to evolve.";
        progress += 25;
    }

    if(progress > 100) progress = 100;

    document.getElementById("infoBox").innerHTML = text;
    document.getElementById("bar").style.width = progress + "%";

    if(progress >= 100){
        document.getElementById("infoBox").innerHTML =
        "<span class='highlight'>Planet Restored</span><br>Life is thriving once again.";
    }
}
</script>

</body>
</html>
